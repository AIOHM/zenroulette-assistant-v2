{
  "manifest_version": 3,
  "name": "ZenRoulette Assistant",
  "description": "Highlights strategic bet numbers based on recent and favorite results.",
  "version": "2.1.6",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "tabCapture",
    "downloads",
    "sidePanel",
    "webNavigation"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "ZRA"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "all_frames": true,
      "match_origin_as_fallback": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "matches": [
        "http://*/*",
        "https://*/*",
        "https://*.vladcazino.ro/*",
        "https://*.evo-games.com/*",
        "https://*.wirebankers.com/*",
        "https://*.live.wirebankers.com/*",
        "https://*.fortunejack.com/*",
        "https://*.bc.game/*"
      ],
      "js": ["strategy-core.js", "app.js"]
    },
    {
      "all_frames": true,
      "match_origin_as_fallback": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "matches": [
        "http://*/*",
        "https://*/*",
        "https://*.vladcazino.ro/*",
        "https://*.evo-games.com/*",
        "https://*.wirebankers.com/*",
        "https://*.live.wirebankers.com/*",
        "https://*.fortunejack.com/*",
        "https://*.bc.game/*"
      ],
      "js": ["main-world.js"],
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "/icons/icon16.png",
    "48": "/icons/icon48.png",
    "128": "/icons/icon128.png"
  }
}
